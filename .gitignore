# Rust
target/
*.rs.bk
**/*.rs.bk

# npm packaging build artifacts — entire dist layout is generator-driven
# from scripts/prepare-release.mjs into dist-packs/pkgs/, binaries copied
# in by scripts/copy-binary.mjs / scripts/build-all.mjs, tarballs produced
# by scripts/pack-all.mjs at dist-packs/*.tgz.
dist-packs/

# Claude Code: track command/skill definitions, ignore per-session state
.claude/*
!.claude/commands/
!.claude/skills/

# Generated cache dirs (produced by the tool itself while dogfooding)
.svelte-check/
.svelte-kit/

# Insta snapshot pending files
*.snap.new
*.pending-snap

# Node tooling (tsgo is installed via npm; we don't track its bytes)
node_modules/
package-lock.json

# IDE / editor
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example

# Logs
*.log

# Local benchmark workspaces (cloned third-party repos used to dogfood
# the binary against real-world codebases — never committed)
bench/

# Private working notes
ROADMAP.md
V0.3.md
