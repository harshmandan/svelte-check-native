{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "isolatedModules": false,
        "lib": ["ES2022", "DOM"]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.d.ts"
    ]
}
