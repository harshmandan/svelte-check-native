{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "noEmit": true,
        "allowJs": true,
        "checkJs": true,
        "allowImportingTsExtensions": true,
        "isolatedModules": false
    },
    "include": [
        "src/**/*.js",
        "src/**/*.ts",
        "src/**/*.d.ts"
    ]
}
