{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": true,
        "allowArbitraryExtensions": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": []
    },
    "include": ["clean.ts", "broken.ts", "component.svelte.svn.js", "svelte-min.d.ts"]
}
