{
  "private": true,
  "name": "svelte-check-native-monorepo",
  "version": "0.0.0",
  "description": "Monorepo root for svelte-check-native. The published package lives at npm/svelte-check-native/.",
  "scripts": {
    "build:rust": "cargo build --release -p svelte-check-native",
    "build:native": "npm run build:rust && node scripts/copy-binary.mjs",
    "pack:all": "node scripts/pack-all.mjs"
  },
  "devDependencies": {
    "@typescript/native-preview": ">=7.0.0-dev.0"
  }
}
